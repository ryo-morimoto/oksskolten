{
  "name": "oksskolten-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "bundle:defuddle": "node scripts/bundle-defuddle.mjs",
    "predev": "node scripts/bundle-defuddle.mjs",
    "dev": "wrangler dev",
    "predeploy": "node scripts/bundle-defuddle.mjs",
    "deploy": "wrangler deploy",
    "pretest": "node scripts/bundle-defuddle.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "d1:create": "wrangler d1 create oksskolten",
    "d1:migrate": "wrangler d1 migrations apply oksskolten --local",
    "d1:migrate:remote": "wrangler d1 migrations apply oksskolten --remote"
  },
  "dependencies": {
    "defuddle": "^0.14.0",
    "fast-xml-parser": "^5.5.8",
    "feedsmith": "^2.9.1",
    "hono": "^4.7.0",
    "linkedom": "^0.18.12",
    "turndown": "^7.2.2"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.13.3",
    "@cloudflare/workers-types": "^4.20260317.1",
    "@types/turndown": "^5.0.6",
    "esbuild": "^0.27.4",
    "typescript": "^5.7.3",
    "vitest": "^4.1.0",
    "wrangler": "^4.14.0"
  }
}
